<style>
@keyframes lspin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
@keyframes lpop{0%{transform:scale(0.8);opacity:0}60%{transform:scale(1.1)}100%{transform:scale(1);opacity:1}}

.header-container {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
}

.rx-text-block {
  flex: 1;
  min-width: 0;
}

.rx-intro-text {
  margin: 0;
  font-size: 24px;
  line-height: 1.5;
  color: #2c2c2a;
}

