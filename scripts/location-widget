  font-size:14px;font-weight:500;color:#2c2c2a;
  font-family:inherit;border:none;
  border-bottom:2px solid #3884a4;
  background:transparent;outline:none;
  padding:0 2px;width:52px;line-height:1.3;border-radius:0;
}
